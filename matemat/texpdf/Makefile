# vim: set ft=make :

include ../../Makefile.inc

.DEFAULT_GOAL := all

#  phony {{{1

.PHONY: debug

.PHONY: html

.PHONY: sync-html

.PHONY: $(ALL_SUBDIRS)
.PHONY: all install

.PHONY: $(CLEAN_SUBDIRS) $(CLEAN_HTML_SUBDIRS) $(WIPE_SUBDIRS)

.PHONY: clean clean-html wipe

# variables {{{1

PARENT_ORG_FILES  = $(wildcard ../*.org)
ORG_FILES         = $(patsubst ../%.org,%.org,$(PARENT_ORG_FILES))
ORG_TEX_FILES     =  $(ORG_FILES:.org=.tex)
ORG_PDF_FILES     =  $(ORG_FILES:.org=.pdf)

# debug {{{1

debug:
	@echo $(SUBDIRS)
	# @echo $(ORG_FILES)
	# @echo $(ORG_TEX_FILES)
	# @echo $(ORG_PDF_FILES)

# org symlinks from parent dir {{{1

%.org: ../%.org
	ln -s $< $@

org: $(ORG_FILES)

# org -> tex {{{1

%.tex: %.org $(INC_FILES) $(INC_LATEX_FILES)
	$(EMACS) $(EMACS_PRE_FLAGS) $< $(EMACS_POST_FLAGS_TEX)
	mv ../$@ .
	@$(ECHO)

tex: $(ORG_TEX_FILES)

# tex --> pdf {{{1

%.pdf: %.tex
	latexmk -f -pdf -shell-escape $<

# all, install {{{1

$(ALL_SUBDIRS):
	$(MAKELINE) -C ${@:all-%=%} all

all: $(ALL_SUBDIRS) clean

# clean, wipe {{{1

$(CLEAN_SUBDIRS):
	$(MAKELINE) -C ${@:clean-%=%} clean
	@$(ECHO)

$(CLEAN_HTML_SUBDIRS):
	$(MAKELINE) -C ${@:clean-html-%=%} clean-html
	@$(ECHO)

$(WIPE_SUBDIRS):
	$(MAKELINE) -C ${@:wipe-%=%} wipe
	@$(ECHO)

clean: $(CLEAN_SUBDIRS)
	rm -f ?*~
	rm -f ?*.aux
	rm -f ?*.fls
	rm -f ?*.fdb
	rm -f ?*.fdb_latexmk
	rm -f ?*.log
	rm -f ?*.out
	rm -f ?*.toc
	rm -f ?*.ptc
	# only here because it is generated by emacs org export
	#rm -f ?*.tex

clean-html: $(CLEAN_HTML_SUBDIRS)
	rm -f ?*.html
	rm -f ?*~

wipe: $(WIPE_SUBDIRS)
	rm -f ?*.html
	rm -f ?*~
